#!/usr/bin/env python3
"""Print the SOF topology ABI of the shipped firmware, offline.

The bug this guards (see docs/RUNBOOK.md "SOF audio"): the kernel's SOF driver
supports a fixed topology ABI (3.23 on the 7.0 kernel this image ships), but the
alsa-sof-firmware package moved its topologies to a newer ABI (3.29). A topology
built at an ABI newer than the kernel understands fails to instantiate at runtime
("FW reported error: 9", "failed widget list set up"), and WirePlumber then
re-links the dead sink in a tight loop until PipeWire abandons the card. The
kernel logs exactly this as e.g. "Topology: ABI 3:29:1 Kernel ABI 3:23:1".

build_files/build.sh pins the firmware to an ABI<=3.23 build; this helper lets the
build gate and tests/smoke.sh *verify* that pin held, with no booted kernel.

It reads the same value the kernel logs, two ways:

1. Authoritative: the ALSA topology manifest block. A .tplg is a sequence of
   `struct snd_soc_tplg_hdr` blocks; the manifest block (type 8) carries a
   `struct snd_soc_tplg_manifest` whose private data begins with the packed SOF
   ABI version. The kernel reads exactly this u32. Its byte offset within the
   manifest payload equals the manifest's own `size` field, so we don't depend on
   a struct that grew fields across versions.

2. Fallback: SOF wraps DSP/component blobs in `struct sof_abi_hdr` with magic
   0x00464F53 ("SOF\\0") and the same packed ABI at offset +12. Scanning for it
   catches topologies whose manifest we couldn't walk.

ABI is packed as (major << 24) | (minor << 12) | patch. Every block in a given
firmware build carries that build's SOF_ABI_VERSION, so the maximum ABI found
across the shipped .tplg files is the topology ABI.

Usage:
    bazzite-tower-sof-abi [PATH ...]
PATH may be a .tplg file or a directory (scanned recursively for *.tplg).
Default: /usr/lib/firmware/intel/sof-tplg

Prints "MAJOR MINOR PATCH" (e.g. "3 23 1") for the highest ABI found and exits 0.
Exits 2 if no ABI could be read from any input (caller decides severity).
"""
import os
import struct
import sys

DEFAULT_PATH = "/usr/lib/firmware/intel/sof-tplg"

TPLG_MAGIC = 0x41536F43          # SND_SOC_TPLG_MAGIC, "CoSA" in file order
TPLG_TYPE_MANIFEST = 8           # SND_SOC_TPLG_TYPE_MANIFEST
TPLG_HDR_LEN = 36                # 9 x __le32
SOF_ABI_MAGIC = b"SOF\x00"       # struct sof_abi_hdr magic, 0x00464F53


def _unpack_abi(packed: int) -> tuple[int, int, int]:
    return ((packed >> 24) & 0xFF, (packed >> 12) & 0xFFF, packed & 0xFFF)


def _sane(ver: tuple[int, int, int]) -> bool:
    # A real SOF ABI is 3.x today; reject stray byte coincidences.
    return 0 < ver[0] <= 9


def abi_from_manifest(blob: bytes) -> tuple[int, int, int] | None:
    """Walk the topology blocks and read the manifest's packed ABI (authoritative)."""
    best: tuple[int, int, int] | None = None
    pos, end = 0, len(blob)
    while pos + TPLG_HDR_LEN <= end:
        magic, _abi, _ver, btype, hsize, _vt, psize = struct.unpack_from(
            "<7I", blob, pos
        )
        if magic != TPLG_MAGIC or hsize < TPLG_HDR_LEN:
            break  # not a valid block stream from here
        payload = pos + hsize
        if btype == TPLG_TYPE_MANIFEST and payload + 4 <= end:
            # manifest.size (first u32) == byte offset of priv.data within payload.
            (man_size,) = struct.unpack_from("<I", blob, payload)
            abi_off = payload + man_size
            if 0 < man_size < psize and abi_off + 4 <= end:
                (packed,) = struct.unpack_from("<I", blob, abi_off)
                ver = _unpack_abi(packed)
                if _sane(ver) and (best is None or ver > best):
                    best = ver
        nxt = payload + psize
        if nxt <= pos:  # malformed: no forward progress
            break
        pos = nxt
    return best


def abi_from_sof_magic(blob: bytes) -> tuple[int, int, int] | None:
    """Scan for sof_abi_hdr blobs and read their packed ABI (fallback)."""
    best: tuple[int, int, int] | None = None
    start = 0
    while True:
        idx = blob.find(SOF_ABI_MAGIC, start)
        if idx < 0:
            break
        start = idx + 1
        off = idx + 12  # magic, type, size, abi
        if off + 4 > len(blob):
            continue
        (packed,) = struct.unpack_from("<I", blob, off)
        ver = _unpack_abi(packed)
        if _sane(ver) and (best is None or ver > best):
            best = ver
    return best


def abi_of_file(path: str) -> tuple[int, int, int] | None:
    try:
        with open(path, "rb") as fh:
            blob = fh.read()
    except OSError:
        return None
    return abi_from_manifest(blob) or abi_from_sof_magic(blob)


def iter_tplg(paths: list[str]) -> list[str]:
    files: list[str] = []
    for path in paths:
        if os.path.isdir(path):
            for root, _dirs, names in os.walk(path):
                files.extend(
                    os.path.join(root, n) for n in names if n.endswith(".tplg")
                )
        elif os.path.isfile(path):
            files.append(path)
    return files


def main() -> int:
    paths = sys.argv[1:] or [DEFAULT_PATH]
    overall: tuple[int, int, int] | None = None
    for tplg in iter_tplg(paths):
        ver = abi_of_file(tplg)
        if ver and (overall is None or ver > overall):
            overall = ver
    if overall is None:
        print("no SOF topology ABI found", file=sys.stderr)
        return 2
    print(f"{overall[0]} {overall[1]} {overall[2]}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
